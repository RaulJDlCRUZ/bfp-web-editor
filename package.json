{
  "name": "bfp-web-editor",
  "version": "0.2.9",
  "main": "index.js",
  "keywords": [
    "bfp",
    "tfg",
    "web",
    "editor",
    "typescript",
    "nodejs",
    "tfggii"
  ],
  "author": "Raúl Jiménez de la Cruz",
  "license": "ISC",
  "type": "module",
  "description": "Fases 3 del proyecto BFP: Persistencia mejorada con BD",
  "dependencies": {
    "@tailwindcss/vite": "^4.0.12",
    "axios": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.16.0",
    "react": "^19.0.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.15.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^1.3.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-image-rendering": "^1.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:svglib:check": "dpkg -l | grep librsvg2-bin",
    "test:svglib:install": "sudo apt-get install librsvg2-bin",
    "curl_template_legacy": "curl -X GET 'https://www.felixalbertos.com/files/tfggii.zip' -o tfggii.zip && unzip -d tfggii tfggii.zip && rm tfggii.zip",
    "get_template": "chmod +x ./fetchTemplate.sh && bash ./fetchTemplate.sh",
    "remove_template": "rm -rf tfggii/",
    "backend:build": "npx tsc -p src/server",
    "backend:start": "node dist/src/index.js",
    "backend:dev": "DEBUG=* NODE_ENV=development tsx watch src/server/src/index.ts",
    "backend:devdist": "DEBUG=* PORT=5000 NODE_ENV=development node --watch dist/src/index.js",
    "client:build": "vite build --config src/client/vite.config.ts",
    "client:dev": "vite --config src/client/vite.config.ts",
    "client:preview": "vite preview --config src/client/vite.config.ts",
    "client:lint": "eslint src/client --ext .ts,.tsx",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run client:dev\"",
    "build": "npm run backend:build && npm run client:build",
    "clean": "rm -rf dist",
    "start": "npm run build && npm run backend:start"
  }
}